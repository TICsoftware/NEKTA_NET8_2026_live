    });
}); *@

        $(document).on("click", ".btn-delete", function (e) {
            e.preventDefault();
            e.stopPropagation();
            if (!confirm("Remove this spot?")) return;

            $.post('/ContentSpotMapping/DeleteMapping',
                { id: $(this).data("id"), contId: $(this).data("cont") },
                () => reloadLayoutForm()
            );

            var mapping_list_has_records = "@(mappingList != null && mappingList.Rows.Count > 0 ? "1" : 0)";
            if (mapping_list_has_records == "1") {
                $("#sortableBody").sortable({
                    handle: ".drag-handle",
                    update: function () {

                        var order = [];

                        $("#sortableBody tr").each(function (index) {
                            order.push({
                                id: $(this).data("id"),
                                sequence: index + 1
                            });
                        });

                        // 🔹 Save order via AJAX
                        $.ajax({
                            url: '/ContentSpotmapping/UpdateOrder',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(order),
                            success: function () {
                                reloadLayoutForm();
                                console.log("Sequence updated");
                            },
                            error: function () {
                                alert("Failed to update order");
                            }
                        });
                    }
                });
            }

             if($(".spot-checkbox").length>0)
            {
                $("#btnsubmit_spot_templates").text("Save and Continue");
            }
            else
            {
                $("#btnsubmit_spot_templates").text("Close");
            }


        });
    function showLayout(e, encId) {
        e.preventDefault();
        e.stopPropagation();
        fetch('/ContextReference/Render?encId=' + encId)
            .then(r => r.json())
            .then(d => {
                $("#layoutContainer").html(d.finalHtml);
                $("#layoutModal").modal('show');
            });
    }

    function showLayoutTemplate(e, encId) {
        e.preventDefault();
        e.stopPropagation();
        $.get('/MainSpotTemplateDetails/ViewLayout', { id: encId }, html => {
            $("#layoutContainerTemplate").html(html);
            $("#layoutModalTemplate").modal('show');
        });
    }

    function load_selected_spot_templates_List() {  
        window.parent.load_spot_templates_List();

    }
</script>