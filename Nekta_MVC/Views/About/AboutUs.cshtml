@using Nekta_MVC.Helpers
@model Nekta_BusinessLogic.Entity.AboutModel
@{
   ViewData["Title"] = "Leadership";
   Layout = "~/Views/Shared/_Layout.cshtml";
}

@section head {
   <title>@Model.Content.cont_window_title</title>

   <meta content="@Model.Content.cont_metatag" name="keywords" />
   <meta content="@Model.Content.cont_metadesc" name="description" />


   <meta name="twitter:card" content="summary" />
   <meta name="twitter:site" content="" />
   <meta name="twitter:title" content="@Model.Content.ContTitle" />
   <meta name="twitter:description" content="@Model.Content.cont_metadesc" />


   <meta property="og:type" content="article" />
   <meta property="og:site_name" content="Nekta" />
   <meta property="og:title" content="@Model.Content.ContTitle" />
   <meta property="og:description" content="@Model.Content.cont_metadesc" />
   <meta property="og:url" content="https://www.nekta.com/" />
   <meta property="og:image" content="@Model.Content.cont_meta_image" />

   <meta itemprop="name" content="Nekta" />
   <meta itemprop="description" content="@Model.Content.cont_metadesc" />
   <meta itemprop="image" content="@Model.Content.cont_meta_image" />

   <!-- Facebook / Open Graph -->
   <meta property="og:type" content="website" />
   <meta property="og:site_name" content="Nekta" />
   <meta property="og:title" content="@Model.Content.ContTitle" />
   <meta property="og:description" content="@Model.Content.cont_metadesc" />
   <meta property="og:image" content="@Model.Content.cont_meta_image" />
   <meta property="og:url" content="https://www.nekta.com/" />

   <link rel="canonical" href="@Model.Content.CanonicalUrl" />
}

@section Styles {
   <link rel="stylesheet" href="~/Assets/css/center-mode-slider.css">
   <link rel="stylesheet" href="~/Assets/css/three-box-slider.css">
   <link rel="stylesheet" href="~/Assets/css/three-tilt-card.css">
   <link rel="stylesheet" href="~/Assets/css/about-us.css" />
}


<!-- HERO BANNER END-->
<section class="relative inside-banner-outer overflow-hidden">
   <div class="inside-banner-inner banner-animation relative ">

      <!-- Banner -->
      <div
         class="rounded-bottom-lr overflow-hidden h-170 rounded-bl-xl rounded-br-xl relative innerbanner-image-wrapper">

         <!-- Parallax Image -->
         <picture>
            <!-- Desktop -->
            <source media="(min-width:1024px)" srcset="@Model.Content.MastheadImage">

            <!-- Tablet -->
            <source media="(min-width:768px)" srcset="@Model.Content.MobileMastheadImage">

            <!-- Mobile -->
            <img src="@Model.Content.MobileMastheadImage" alt="@Model.Content.Masthead_image_Alt_text"
                 class="innerbanner-image absolute left-0 top-0 w-full h-full object-cover" loading="eager"
                 fetchpriority="high">
         </picture>

         <!-- Keep Existing Overlay -->
         <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70 z-10"></div>


      </div>

      <!-- Content -->

      <div class="innerbanner-caption absolute inset-0 z-30 flex items-end">
         <div class="container pb-12 md:pb-15">
            <div class="max-w-4xl text-left">

               <nav class="mb-4" aria-label="Breadcrumb">
                  @Html.Raw(Model.Content.BreadcrumPath)
               </nav>

               <h1 class="innerbanner-title text-h1 text-white">
                  @Html.Raw(
                    !string.IsNullOrWhiteSpace(Model.Content.Cont_hmpg_intro)
                    ? Model.Content.Cont_hmpg_intro.CleanParagraphTags()
                    : Model.Content.ContTitle)
               </h1>

            </div>
         </div>
      </div>

           
   </div>
</section>

<!-- INTRO SECTION -->
@if (!string.IsNullOrWhiteSpace(Model?.Content?.Cont_intro))
{
   <section class="section-spacing">
      <div class="container">
         <div class="max-w-5xl mx-auto text-center intro-section-wrap">
            @Html.Raw(Model.Content.Cont_intro)
         </div>
      </div>
   </section>
}
<!-- INTRO SECTION END -->

<!-- THREE TILT CARD -->
@foreach (var item in Model.Component_With_Cards_List.Where(x => x.IsBlock == 0))
{
   <section class="story-gallery">       
      <div class="container">
         <div class="story-gallery-wrap">
            <div class="story-gallery-left">
               <img src="@item.Component_Icon_Image" class="max-w-auto">
            </div>
            <div class="story-gallery-right">
               <img src="@item.Component_Icon2_Image" class="max-w-auto z-10 story-turmuric">
               <img src="@item.Component_Icon3_Image" alt="" class="max-w-auto z-10 story-leaf">
            </div>
            <!-- Cards -->
            <div class="cards-wrapper relative flex justify-center items-center">
               <!-- Left -->
               <div class="gallery-card gallery-left">
                  <img src="@item.Component_LHS_thumbnail" alt="@item.Component_LHS_thumbnail_image_alt">
               </div>
               <!-- Center -->
               <div class="gallery-card gallery-center">
                  <img src="@item.ComponentThumbnail" alt="@item.ComponentThumbnailAltText">
               </div>
               <!-- Right -->
               <div class="gallery-card gallery-right">
                  <img src="@item.Component_right_image" alt="@item.Component_Right_image_alt">
               </div>
            </div>
         </div>
      </div>        
   </section>
}
<!-- THREE CARDS END -->

<!-- COOUNTER SECTION -->
<section class="counter-section section-pb">
   <div class="container">
      <div class="counter-wrapper sm:max-w-4xl sm:mx-auto">
         <!-- Counter -->

         @foreach (var item in Model.infographics_List
                     .Where(x => x.IsBlock == 1)
                     .OrderBy(x => x.Sequence))
         {

                        
            <div class="flex flex-col shrink-0 rounded-2xl px-4 py-6 items-start gap-0 box-itm counter-item">
             

               @Html.Raw(item.Intro.CleanParagraphTags())

               <p>@item.Title</p>
            </div>

            @if (item.Sequence != Model.infographics_List.Where(x => x.IsBlock == 1).Max(x => x.Sequence))
            {
               <div class="counter-divider"></div>
            }
         }

      </div>
   </div>
</section>
<!-- COUNTER SECTION ENd -->


<!-- ENQUIRY NOW CTA -->
@foreach (var item in Model.Access_to_Safe_List.Where(x => x.IsBlock == 0))
{
   <section class="cta-section section-spacing">
      <div class="container">
         <div class="max-w-5xl mx-auto text-center">
            <h2>
               @Html.Raw(
                       !string.IsNullOrWhiteSpace(item.DisplayTitle)
                       ? item.DisplayTitle.CleanParagraphTags()
                       : item.Title)
            </h2>

            @if (!string.IsNullOrWhiteSpace(item.Url))
            {
               <a href="@item.Url" class="common-btn mt-8 md:mt-12 btn-slide-fill" type="button"
                  data-modal-open="contactModal">
                  <span>@(!string.IsNullOrWhiteSpace(item.Url_Text) ? item.Url_Text : "Enquire Now")</span>
                  <img loading="lazy" src="/Assets/images/arrows/creamarrow-long-right.png" alt="rightArrow" />
               </a>
            }
         </div>
      </div>
   </section>
}
<!-- ENQUIRY NOW CTA END-->


<!-- ==================== 
         6: Who we are
         ==================== -->
<section class="bg-green center-slider relative section-spacing overflow-hidden">
   <div class="inner-center-slider">
      @foreach (var item in Model.Who_Are_We_List.Where(x => x.IsBlock == 0))
      {
         <div class="text-center mb-6 px-6 mx-auto max-w-5xl section-title--light-outer">
            <h2 class="section-title section-title--light" data-leaf-target letters-slide-down text-split>
               @Html.Raw(
                              !string.IsNullOrWhiteSpace(item.DisplayTitle)
                              ? item.DisplayTitle.CleanParagraphTags()
                              : item.Title)
            </h2>
         </div>
               <!-- Sub Intro with Read More -->
                  <div class="sub-intro-wrapper mt-4 max-w-5xl mx-auto text-center relative">
                     <div class="sub-intro-text-outer" data-subintro-outer>
                        <div class="sub-intro-text" data-subintro>
                           @Html.Raw(item.Intro)
                        </div>
                        <div class="sub-intro-fade" data-subfade></div>
                     </div>
                     <button type="button" class="read-more-btn" data-readmore-toggle>
                        <span data-readmore-label>Read More</span>
                     </button>
                  </div>
      }

      <!-- Swiper Slider -->
      <div class="swiper edgeSwiper px-4 py-6">
         <div class="swiper-wrapper py-4 pb-2">
            <!-- Slide 1 -->
            @foreach (var item in Model.Who_Are_We_List.Where(x => x.IsBlock == 1))
            {
               <div class="swiper-slide">
                  <div class="edge-card group backdrop-blur-sm opacity-50 transition-all duration-700">
                     <img loading="lazy" src="@item.ThumbnailImage" alt="@item.ThumbnailAltText"
                          class="edge-card-image border-8 w-full aspect-video object-cover transition-all duration-700" />
                     <div
                        class="edge-arrow-bar absolute w-full -translate-y-1/4 flex justify-between items-center gap-8 mt-0 edgeArrow hidden">
                        <div
                           class="edge-swiper-prev edge-prev cursor-pointer w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 relative rounded-full bg-cream border border-green flex items-center justify-center text-white transition-all">
                           <img loading="lazy" src="/Assets/images/arrows/GreenLeft.png" alt="GreenLeft" />
                        </div>
                        <div
                           class="edge-swiper-next edge-next cursor-pointer w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 relative rounded-full bg-cream border border-green flex items-center justify-center text-white transition-all">
                           <img loading="lazy" src="/Assets/images/arrows/GreenRight.png" alt="GreenRight" />
                        </div>
                     </div>
                     <div
                        class="edge-details p-0 pt-1 flex flex-col md:flex-row items-start justify-between opacity-0 invisible transition-all duration-500">
                        <div>
                           <h3 class="edge-card-title">
                              @item.Title
                           </h3>
                           <p class="edge-card-text">
                              @Html.Raw(item.Intro.CleanParagraphTags())
                           </p>
                        </div>
                        <div>

                        </div>
                     </div>
                  </div>
               </div>
            }
         </div>

         <div class="edge-nav-arrows">
            <div
               class="edge-swiper-prev cursor-pointer w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 rounded-full bg-cream border border-green flex items-center justify-center transition-all">
               <img loading="lazy" src="/Assets/images/arrows/GreenLeft.png" alt="GreenLeft" />
            </div>
            <div
               class="edge-swiper-next cursor-pointer w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 rounded-full bg-cream border border-green flex items-center justify-center transition-all">
               <img loading="lazy" src="/Assets/images/arrows/GreenRight.png" alt="GreenRight" />
            </div>
         </div>

      </div>
   </div>
</section>

<!-- ==================== FOOTPRINT SECTION ==================== -->
@foreach (var item in Model.Our_Footprint_List.Where(x => x.IsBlock == 0))
{
   <section class="footprint-section section-spacing overflow-hidden">
      <div class="container">
         <!-- Heading -->
         <!-- Section Heading -->
         <div class="section-title-outer text-center mx-auto max-w-5xl">
            <h2 class="title-section text-h2 " data-leaf-target letters-slide-down text-split>
               @Html.Raw(
                     !string.IsNullOrWhiteSpace(item.DisplayTitle)
                     ? item.DisplayTitle.CleanParagraphTags()
                     : item.Title)
            </h2>

         </div>
         
      

         <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <!-- Left Content -->
            <div class="relative ">
               <!-- Decorative -->
               <div class="footprint-decor-img">
                  <img src="@item.ComponentThumbnail" alt="@item.ComponentThumbnailAltText"
                       class="footprint-decor absolute -left-16 -top-[50%]  pointer-events-none select-none">
               </div>
               <div class="left-copy">
                  @Html.Raw(item.Intro)
               </div>
            </div>
            <!-- Right Image -->
            <div class="relative map-outer-warapper">
               @Html.Raw(item.Content)

            </div>
         </div>
      </div>
   </section>
}
<!-- ==================== DIVERSE PLAYGROUNDS SECTION ==================== -->
<!-- ==================================
         4: Diverse Playgrounds. Singular Spirit
         =================================== -->
<section id="playgrounds-section" class="bg-cream section-spacing relative overflow-hidden">
   <img src="assets/images/bg-pattern.webp" alt="" class="w-full h-full absolute top-0 left-0" />
   <div class="container">
      <!-- Section Heading -->
      @foreach (var item in Model.Singular_Spirit_Aboutus_List.Where(x => x.IsBlock == 0))
      {
         <div class="section-title-outer text-center mx-auto max-w-5xl">
            <h2 class="title-section text-h2 " data-leaf-target letters-slide-down text-split>
               @Html.Raw(
                       !string.IsNullOrWhiteSpace(item.DisplayTitle)
                       ? item.DisplayTitle.CleanParagraphTags()
                       : item.Title)
            </h2>
         </div>
      }

      <!-- Swiper Slider Container -->
      <div class="swiper mySwiper three-box-slider px-0 md:px-4 pt-10">
         <div class="swiper-wrapper">
            <!-- Slide 1 -->
            @foreach (var item in Model.Singular_Spirit_Aboutus_List.Where(x => x.IsBlock == 1))
            {
               <div class="swiper-slide group cursor-pointer">
                  <div class="feature-card">
                     <div class="playground-media w-full overflow-hidden rounded-t-full mb-6 relative">
                        <img loading="lazy" src="@item.ThumbnailImage" alt="@item.ThumbnailAltText"
                             class="playground-image w-full h-full object-cover transition-transform duration-700" />
                        <div
                           class="absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/70 to-transparent  text-center">
                           <h3 class="text-white">@item.Title</h3>
                        </div>
                     </div>

                     @if (!string.IsNullOrWhiteSpace(item.Url))
                     {
                        <a href="@item.Url" class="link-md link-dark">
                           <span class="underline">
                              @(string.IsNullOrWhiteSpace(item.Url_Text) ? "Learn More" : item.Url_Text)
                           </span>
                           <img loading="lazy" src="/Assets/images/arrows/blackarrow-long-right.png" alt="→" />
                        </a>
                     }
                  </div>
               </div>
            }

            <!-- Slider Navigation -->
            <div class="flex justify-center items-center gap-4 md:gap-6 mt-8 md:mt-12  w-auto!">
               <div
                  class="swiper-button-prev-custom cursor-pointer w-10 h-10 md:w-12 md:h-12 rounded-full bg-green flex items-center justify-center text-cream transition-all hover:scale-110">
                  <img loading="lazy" src="/Assets/images/arrows/swiperLeft.png" alt="swiperLeft" />
               </div>
               <div class="swiper-pagination-custom flex items-center justify-center gap-3 md:gap-4"></div>
               <div
                  class="swiper-button-next-custom cursor-pointer w-10 h-10 md:w-12 md:h-12 rounded-full bg-green flex items-center justify-center text-cream transition-all hover:scale-110">
                  <img loading="lazy" src="/Assets/images/arrows/swiperRight.png" alt="swiperRight" />
               </div>
            </div>

         </div>
      </div>
   </section>


   @section Scripts {
      <script src="~/Assets/js/inner-banner-script.js"></script>
      <script src="~/Assets/js/center-mode-slider.js"></script>
      <script src="~/Assets/js/three-box-slider.js"></script>
      <script src="~/Assets/js/three-tilt-card.js"></script>
      <script src="~/Assets/js/about-us.js"></script>
   }