@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<ComponentModel>

<section class="section-spacing relative overflow-hidden">
    <img src="/Assets/images/bg-pattern.webp" alt="" class="w-full h-full absolute top-0 left-0" />
    <div class="container">
        @foreach (var item in Model.Where(x => x.IsBlock == 0))
        {
            <div class="section-title-outer text-center max-w-6xl mx-auto">
                <h2 class="title-section text text-h2" data-leaf-target letters-slide-down text-split>
                    @Html.Raw(
                    !string.IsNullOrWhiteSpace(item.DisplayTitle)
                    ? item.DisplayTitle.CleanParagraphTags()
                    : item.Title)
                </h2>
                @if (!string.IsNullOrWhiteSpace(item.Intro))
                {
                    @Html.Raw(item.Intro)
                }
            </div>
        }

        <div class="swiper insightsSwiper px-2 md:px-4 blogs-cards-slider">
            <div class="swiper-wrapper">
                @foreach (var item in Model.Where(x => x.IsBlock == 1).OrderBy(x => x.Sequence))
                {
                    <div class="swiper-slide h-auto">
                        <div class="insight-card group blogs-cards-wrapper">
                            <div class="media-frame overflow-hidden rounded-lg ratio-[531/315] blogs-cards-image">
                                <img loading="lazy" src="@item.ThumbnailImage" alt="@item.ThumbnailAltText"
                                    class="w-full object-cover" />
                            </div>
                            <div class="py-6 blogs-cards-content">
                                @if (!string.IsNullOrWhiteSpace(item.Section_title))
                                {
                                    <span
                                        class="pill inline-block bg-green text-cream text-xs font-medium px-2.5 py-1 rounded-lg">@item.Section_title</span>
                                }
                                <h3 class="insight-title line-clamp-2">@item.Title</h3>
                                @if (!string.IsNullOrWhiteSpace(item.Url))
                                {
                                    <a href="@item.Url" class="link-md link-primary mt-4">
                                        <span class="underline">@(string.IsNullOrWhiteSpace(item.Url_Text) ? "Read More" : item.Url_Text)</span>
                                        <img loading="lazy" src="/Assets/images/arrows/orangearrow-long-right.png"
                                            alt="rightArrow" />
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="blogs-slider-nav">
                <button class="blogs-prev" aria-label="Previous">
                    <img src="/Assets/images/arrows/swiperLeft.png" alt="swiperLeft" class="max-w-full">
                </button>
                <button class="blogs-next" aria-label="Next">
                    <img src="/Assets/images/arrows/swiperRight.png" alt="swiperRight" class="max-w-full">
                </button>
            </div>
        </div>

        @{
            var worksCta = Model.FirstOrDefault(x => x.IsBlock == 0);
        }
        @if (worksCta != null && !string.IsNullOrWhiteSpace(worksCta.Url))
        {
            <div class="flex justify-center mt-6">
                <a href="@worksCta.Url" class="common-btn flex items-center gap-2 btn-slide-fill">
                    <span>@(string.IsNullOrWhiteSpace(worksCta.Url_Text) ? "View All Case Study" : worksCta.Url_Text)</span>
                    <img loading="lazy" src="/Assets/images/arrows/creamarrow-long-right.png" alt="rightArrow" />
                </a>
            </div>
        }
    </div>
</section>
