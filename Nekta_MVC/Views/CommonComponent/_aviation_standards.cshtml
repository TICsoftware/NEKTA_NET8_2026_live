@using Nekta_BusinessLogic.Entity
@using Nekta_MVC.Helpers
@model List<ComponentModel>

@{
    var avHeader = Model.FirstOrDefault(x => x.IsBlock == 0);
    var avItems = Model
        .Where(x => x.IsBlock == 1)
        .OrderBy(x => x.Sequence)
        .ToList();
    var firstAv = avItems.FirstOrDefault();
}

<section class="av-section relative section-spacing overflow-hidden">
    <div class="container relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <div class="relative av-media-wrap">
                <div class="av-arch">
                    @if (firstAv != null)
                    {
                        <img id="avImage" src="@firstAv.ThumbnailImage" alt="@firstAv.ThumbnailAltText" data-av-image />
                    }
                </div>

                <button class="av-arrow av-arrow-prev" type="button" aria-label="Previous certification" data-av-prev>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="av-arrow av-arrow-next" type="button" aria-label="Next certification" data-av-next>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                </button>
            </div>

            <div class="relative">
                @if (avHeader != null)
                {
                    <div class="section-title-outer text-center max-w-6xl mx-auto section-title--light-outer">
                        <h2 class="section-title section-title--light" data-leaf-target letters-slide-down text-split>
                            @Html.Raw(
                            !string.IsNullOrWhiteSpace(avHeader.DisplayTitle)
                            ? avHeader.DisplayTitle.CleanParagraphTags()
                            : avHeader.Title)
                        </h2>
                    </div>
                }

                <ul class="av-list" data-av-list>
                    @for (int i = 0; i < avItems.Count; i++)
                    {
                        var avItem = avItems[i];
                        <li class="av-item @(i == 0 ? "active" : "")" data-av-item data-image="@avItem.ThumbnailImage">
                            <span>@avItem.Title</span>
                        </li>
                    }
                </ul>

                <svg class="av-leaf" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true">
                    <path d="M20 2C8 12 4 28 12 42C16 49 22 54 20 58C30 50 36 36 32 22C29 11 24 5 20 2Z"
                        fill="var(--color-cream)" />
                    <path d="M20 6C18 20 18 40 20 56" stroke="var(--color-cream)" stroke-width="1.2"
                        stroke-linecap="round" />
                </svg>
            </div>
        </div>
    </div>
</section>
