                    stroke="#ECE2CF" stroke-width="2" stroke-linecap="round" />
            </svg>
        </div>

        <div class="cu-plate-wrap cu-plate-left" aria-hidden="true">
           
              <img src="@(string.IsNullOrWhiteSpace(item.Component_LHS_icon1) ? "/Assets/images/contact-us/plate-bg-circle.webp" : item.Component_LHS_icon1)" alt="" class="cu-plate-circle">
            <img src="@(string.IsNullOrWhiteSpace(item.Component_LHS_thumbnail) ? "/Assets/images/contact-us/pasta-plate.webp" : item.Component_LHS_thumbnail)"
                alt="" class="cu-plate-img">
            <img src="@(string.IsNullOrWhiteSpace(item.Component_LHS_icon2) ? "/Assets/images/contact-us/coriander.webp" : item.Component_LHS_icon2)" alt="" class="cu-plate-deco cu-coriander">
          
        </div>

        <div class="cu-plate-wrap cu-plate-right" aria-hidden="true">
            <img src="@(string.IsNullOrWhiteSpace(item.Component_RHS_icon1) ? "/Assets/images/contact-us/plate-bg-circle.webp" : item.Component_RHS_icon1)" alt="" class="cu-plate-circle">
            <img src="@(string.IsNullOrWhiteSpace(item.Component_right_image) ? "/Assets/images/contact-us/berry-pancake-plate.webp" : item.Component_right_image)"
                alt="" class="cu-plate-img">
            <img src="@(string.IsNullOrWhiteSpace(item.Component_RHS_icon2) ? "/Assets/images/contact-us/strawberry.webp" : item.Component_RHS_icon2)" alt="" class="cu-plate-deco cu-strawberry">
        </div>

        <div class="container relative text-center">
            <div class="section-title-outer text-center mx-auto max-w-2xl ">
                <h2 class="title-section text-h2 " data-leaf-target letters-slide-down text-split>
                    @Html.Raw(
                    !string.IsNullOrWhiteSpace(item.DisplayTitle)
                    ? item.DisplayTitle.CleanParagraphTags()
                    : item.Title)
                </h2>
            </div>

            @if (!string.IsNullOrWhiteSpace(item.ComponentThumbnail))
            {
                <div class="cu-arch-media mb-5 md:mb-6">
                    <img loading="lazy" src="@item.ComponentThumbnail" alt="@item.ComponentThumbnailAltText" />
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(item.Intro))
            {
                <p class="cu-enquiry-copy">
                    @Html.Raw(item.Intro.CleanParagraphTags())
                </p>
            }
        </div>
    </section>
}
