@model IEnumerable<Core_project_BusinessLogic.Entity.TemplateMaster>

@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    ViewData["Title"] = "List Template Master";
    string returnUrl = Context.Request.Query["ReturnUrl"].ToString();
}

<h2 class="mb-3">@ViewData["Title"]</h2>

<!-- Success message -->
@if (TempData["AlertMessage"] != null)
{
    <div class="alert alert-info">
        @TempData["AlertMessage"]
    </div>
}

<!-- Add New Template Button -->
<div class="mb-3">
    <a asp-action="AddTemplateMaster" class="btn btn-primary">
  Add New
    </a>
</div>

<!-- Table -->
<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Language Master</th>
            <th>Name</th>
            <th>Status</th>
            <th>Created Date</th>
            <th>Updated Date</th>
            <th style="width: 150px;">Actions</th>
        </tr>
    </thead>

    <tbody>
    @using Core_project_BusinessLogic
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.ID</td>
                    <td>@item.Language_Master_ID</td>
                    <td>@item.Name</td>
                    <td>
                        @if (item.Status == 1)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </td>
                    <td>@item.Created_Date?.ToString("dd-MMM-yyyy")</td>
                    <td>@item.Updated_Date?.ToString("dd-MMM-yyyy")</td>

                    <td>
                        
                            @* <a href="/TemplateMaster/EditTemplateMaster?encId=@CryptoEngine.Encrypt(item.ID.ToString())"
                            class="btn btn-sm btn-outline-primary">
                            Edit
                            </a> *@
                         <a asp-action="EditTemplateMaster"  asp-route-Id="@CryptoEngine.Encrypt(item.ID.ToString())" class="btn btn-sm btn-outline-secondary">Edit</a>

                        <!-- Delete -->
                     
  @* <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger">Delete</a> *@

@if (item.Status == 1)   // Only show deactivate for active items
    {
        <a asp-action="Deactivate"
           asp-route-encId="@CryptoEngine.Encrypt(item.ID.ToString())"
           class="btn btn-sm btn-outline-danger"
           onclick="return confirm('Are you sure to deactivate this template?');"> Deactivate
        </a>
    }
    else
    {
        <span class="badge bg-outline-secondary">Inactive</span>
    }


                    
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center text-muted">
                    No templates found.
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        // optional fade-out alert
        setTimeout(function () {
            $(".alert").fadeOut("slow");
        }, 3000);
    </script>
}