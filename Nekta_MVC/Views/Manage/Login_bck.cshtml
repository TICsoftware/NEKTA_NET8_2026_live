@model Nekta_MVC.Models.Manage_Model.User_LoginModel
@{
   Layout = "~/Views/Shared/Manage/_Layout_Login.cshtml";
   ViewData["Title"] = "Login";
   string returnUrl = Context.Request.Query["ReturnUrl"].ToString();
}


<div class="row h-100">
            <div class="col-lg-5 col-12 offset-lg-4">
                <div id="auth-left">
                    <div class="auth-logo">
                        <a href="index.html"><img src="/Assets/compiled/svg/logo.svg" alt="Logo"></a>
                    </div>
                    <h1 class="auth-title">Log in.</h1>
                    <p class="auth-subtitle mb-5">Log in with your data that you entered during registration.</p>
                    @using (Html.BeginForm(
        actionName: "Login",
        controllerName: "Manage",
        routeValues: new { ReturnUrl = returnUrl },
        method: FormMethod.Post,
        antiforgery: true, // Add this!
        htmlAttributes: new { @class = "form-horizontal", role = "form" }))
{
                @Html.AntiForgeryToken()
                <hr />
                @Html.ValidationSummary(true)

                        <div class="form-group position-relative has-icon-left mb-4">
                         @Html.TextBoxFor(m => m.UserName, new { @class = "form-control form-control-xl",@placeholder="Username" })
                        @Html.ValidationMessageFor(m => m.UserName)
                          
                            <div class="form-control-icon">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <div class="form-group position-relative has-icon-left mb-4">
                         @Html.PasswordFor(m => m.Password, new { @class = "form-control form-control-xl", id = "txtPassword", @placeholder="Password" })
                        @Html.ValidationMessageFor(m => m.Password)
                            <div class="form-control-icon">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                        </div>
                        <div class="form-check form-check-lg d-flex align-items-end">
                         @Html.CheckBoxFor(m => m.RememberMe,new {@id="flexCheckDefault",@class="form-check-input me-2"})
                            <!-- @Html.LabelFor(m => m.RememberMe) -->
                           
                            <label class="form-check-label text-gray-600" for="flexCheckDefault">
                                Keep me logged in
                            </label>
                        </div>

                        <button type="submit" name="Command" value="Log in" class="btn btn-primary btn-block btn-lg shadow-lg mt-5" id="btnSubmit">Log in </button>

                   }
                    <div class="text-center mt-5 text-lg fs-4">
                        <p><a class="font-bold" href="auth-forgot-password.html">Forgot password?</a>.</p>
                    </div>
                </div>
            </div>


