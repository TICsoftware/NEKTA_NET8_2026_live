@{
    Layout = "~/Views/Shared/Manage/_Layout_Login.cshtml";
    ViewData["Title"] = "Scan QR Code";
    string returnUrl = Context.Request.Query["ReturnUrl"].ToString();
}
<title>Login -TIC CMS </title>

<link rel="stylesheet" href="/Assets/css/users_login.css" />
<div class="login-container">
    <div class="login-card">

        <!-- Logo -->
        <div class="auth-logo">
            <a href="index.html">
                <img src="/Assets/compiled/svg/logo.svg" alt="Logo">
            </a>
        </div>

        <!-- Title + Subtitle -->
        <h1 class="auth-title">Log in</h1>
        <p class="auth-subtitle">Log in with your data that you entered during registration.</p>

        <form method="post">

            <div class="form-group">
                <label>Username</label>
                <input name="username" placeholder="Enter username" required />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input name="password" type="password" placeholder="Enter password" required />
            </div>

            <!-- Forgot Password -->
            <div class="forgot-password">
                <a href="/Users/ForgotPassword">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-login">Login</button>

        </form>

        <!-- Error Message -->
        @if (ViewBag.Error != null)
        {
            <p class="error-message">@ViewBag.Error</p>
        }

        @* <div class="register-link">
            <small>Don’t have an account? <a href="/Users/Register">Register</a></small>
        </div> *@

    </div>
</div>