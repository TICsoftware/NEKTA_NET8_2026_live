                     </div>
                     <div class="swiper-slide group cursor-pointer">
                        <div class="feature-card">
                           <div class="playground-media w-full overflow-hidden rounded-t-full mb-6 relative">
                              <img loading="lazy" src="assets/images/playgrounds/Education.jpg" alt="Education"
                                 class="playground-image w-full h-full object-cover transition-transform duration-700" />
                              <div class="playground-caption absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/70 to-transparent">
                                 <h3 class="slide-title">Education</h3>
                              </div>
                           </div>
                           <a href="#" class="link-md link-dark">
                           <span class="underline">Learn More</span>
                           <img loading="lazy" src="assets/images/arrows/blackarrow-long-right.png" alt="→" />
                           </a>
                        </div>
                     </div>
                     <div class="swiper-slide group cursor-pointer">
                        <div class="feature-card">
                           <div class="playground-media w-full overflow-hidden rounded-t-full mb-6 relative">
                              <img loading="lazy" src="assets/images/playgrounds/Healthcare.jpg" alt="Healthcare"
                                 class="playground-image w-full h-full object-cover transition-transform duration-700" />
                              <div class="playground-caption absolute bottom-0 left-0 w-full p-6 bg-gradient-to-t from-black/70 to-transparent">
                                 <h3 class="slide-title">Healthcare</h3>
                              </div>
                           </div>
                           <a href="#" class="link-md link-dark">
                           <span class="underline">Learn More</span>
                           <img loading="lazy" src="assets/images/arrows/blackarrow-long-right.png" alt="→" />
                           </a>
                        </div>
                     </div>
                  </div>
                  <!-- Slider Navigation -->
                  <div class="flex justify-center items-center gap-4 md:gap-6 mt-8 md:mt-12 pb-8 md:pb-12">
                     <div class="swiper-button-prev-custom cursor-pointer w-10 h-10 md:w-12 md:h-12 rounded-full bg-green flex items-center justify-center text-cream transition-all hover:scale-110">
                        <img loading="lazy" src="assets/images/arrows/swiperLeft.png" alt="swiperLeft" />
                     </div>
                     <div class="swiper-pagination-custom flex items-center justify-center gap-3 md:gap-4"></div>
                     <div class="swiper-button-next-custom cursor-pointer w-10 h-10 md:w-12 md:h-12 rounded-full bg-green flex items-center justify-center text-cream transition-all hover:scale-110">
                        <img loading="lazy" src="assets/images/arrows/swiperRight.png" alt="swiperRight" />
                     </div>
                  </div>
               </div>
            </div>
         </section>

         <!-- ==================== SIGNATURE CREATIONS SECTION ==================== -->
         <section class="signature-section py-12 md:py-20 relative overflow-hidden group">
            <div
               class="newbox signature-bg absolute inset-0 bg-cover bg-center bg-no-repeat transition-transform duration-1000 ease-out z-0">
            </div>
            <div class="container container--relative signature-content">
               <!-- Section Heading - Initially Hidden, Slides from Left on Hover (desktop) / Always visible on mobile -->
               <div
                  class="signature-heading text-center mb-6 md:mb-8 transition-all duration-700 ease-out opacity-100">
                  <h2 class="section-title" data-leaf-target>
                     Built on Culinary Precision. <br />
                     Delivered With
                     <span class="section-title__accent text-reveal">
                     Hospitality Excellence.
                     </span>
                  </h2>
               </div>
               <!-- Main Plate Image Container -->
               <div class="signature-plate relative mx-auto transition-all duration-700">
                  <img loading="lazy" src="assets/images/signature-plate.png" alt="Signature Dish"
                     class="signature-plate-image w-full h-auto mx-auto transition-all duration-700 ease-out" />
                  <!-- Subtle shine effect on hover -->
                  <div
                     class="signature-shine absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent opacity-0 transition-opacity duration-700 pointer-events-none">
                  </div>
               </div>
            </div>
         </section>

