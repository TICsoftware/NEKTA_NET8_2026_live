                     </div>
                     <!-- Slide 3 -->
                     <div
                        class="swiper-slide transition-all duration-700"
                        >
                        <div
                           class="edge-card group relative backdrop-blur-sm opacity-50 transition-all duration-700"
                           >
                           <img loading="lazy"
                              src="assets/images/edge/cooking.jpg"
