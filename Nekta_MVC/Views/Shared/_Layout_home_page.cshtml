<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
@{
    var nonce = Context.Items["CSPNonce"]?.ToString();
}

  <!-- ✅ Favicon -->
  <link rel="icon" href="~/Assets/images/favicon/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="~/Assets/images/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="~/Assets/images/favicon/favicon-16x16.png">
  <!-- Apple -->
  <link rel="apple-touch-icon" href="~/Assets/images/favicon/apple-touch-icon.png">
  <!-- Android -->
  <link rel="icon" type="image/png" sizes="192x192" href="~/Assets/images/favicon/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="~/Assets/images/favicon/android-chrome-512x512.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link nonce="@nonce" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'">

  @RenderSection("head", required: false)
  
  <link rel="preload" href="~/dist/site.css" as="style"  onload="this.onload=null;this.rel='stylesheet'" asp-append-version="true">
  <link rel="stylesheet" href="~/dist/site.css" asp-append-version="true" />

  
   <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
  <link rel="preload" href="~/Assets/css/header-footer.css" as="style">
  <link rel="stylesheet" href="~/Assets/css/header-footer.css">

  <link rel="preload" href="~/Assets/css/style.css" as="style">
  <link rel="stylesheet" href="~/Assets/css/style.css">

  <link rel="stylesheet" href="~/Assets/css/common-style.css">
  <link rel="stylesheet" href="~/Assets/css/three-box-slider.css">
  


  @RenderSection("Styles", required: false)
</head>

<body>
   <noscript>
    <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KKXV4K9H" height="0" width="0"
      style="display:none;visibility:hidden"></iframe>
  </noscript> 
  
  @{
    var isHomePage =
    ViewContext.RouteData.Values["controller"]?.ToString() == "Home" &&
    ViewContext.RouteData.Values["action"]?.ToString() == "Index";
  }


      <main id="main-content">
         <!-- HERO SECTION -->
         <section class="hero-section relative md:h-screen flex items-center justify-center overflow-hidden">
            <div class="hero-assistant fixed bottom-15 right-0 z-50">
               <button type="button" class="assistant-trigger" data-modal-open="contactModal"
                  aria-label="Open assistant enquiry form">
               <img loading="lazy" src="assets/images/assistant.png" alt="" class="hero-section-ass-img" aria-hidden="true"
                  />
               </button>
            </div>
            <video autoplay muted loop playsinline class="hero-video absolute inset-0 w-full h-full object-cover">
               <source src="assets/video/Bubble.mp4" type="video/mp4" />
            </video>
            <!-- Overlay -->
            <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
            <!-- Floating Particles -->
            <div class="absolute inset-0 pointer-events-none">
               <div
                  class="particle absolute w-1.5 h-1.5 md:w-2 md:h-2 bg-green-400 rounded-full top-1/4 left-5 md:left-10 opacity-30">
               </div>
               <div class="particle absolute w-1 h-1 bg-green-400 rounded-full top-1/3 left-1/4 md:left-1/3 opacity-40"
                  style="animation-delay: 3s"></div>
               <div class="particle absolute w-2 h-2 md:w-3 md:h-3 bg-green-400 rounded-full top-2/3 left-3/4 md:left-2/3 opacity-20"
                  style="animation-delay: 7s"></div>
            </div>
         </section>


         <div class="bg-darkcream py-12 md:py-20 px-4 text-center">
            <h1 class="hero-title">
               Seeking an Elevated
               <span class="section-title__accent text-reveal">
               Dining Experience
               </span>
            </h1>
            <button class="btn-primary mt-8 md:mt-12 btn-slide-fill" type="button" data-modal-open="contactModal">
            <span>Get in Touch</span>
            <img loading="lazy" src="assets/images/arrows/creamarrow-long-right.png" alt="rightArrow" />
            </button>
         </div>

         <!-- ==================== ABOUT SECTION ==================== -->
         <section class="about-section py-24 md:py-24 bg-center bg-no-repeat bg-cover" style="
            background-image: url(&quot;assets/images/about/about-bg.jpg&quot;);
            ">
            <div class="container">
               <div class="about-grid grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
                  <!-- Left Text -->
                  <div class="space-y-6 md:space-y-8">
                     <h2 class="section-title">
                        From the house trusted on air to delighting on
                        ground;<br />
                        Serving up a beautiful world of
                        <span class="section-title__accent text-reveal">
                        food inbetween
                        </span>
                     </h2>
                     <div class="about-copy space-y-6 px-0 md:px-8 relative">
                        <p class="copy-tight" >
                           A hallmark of catering excellence, trusted
                           by institutions, driven by innovation, Nekta
                           Food Solutions Limited is an organization
                           built to elevate the experience of everyday
                           dining into an art.
                        </p>
                        <p class="copy-tight" >
                           Backed by the legacy of TajSATS, India’s
                           market leader in aviation hospitality Nekta
                           brings the agility of youthful innovation
                           and the lived wisdom of experience to
                           everyday institutional dining.
                        </p>
                        <a href="#" class="link-md link-primary" >
                        <span>About us</span>
                        <img loading="lazy" src="assets/images/arrows/orangearrow-long-right.png" alt="rightArrow" />
                        </a>
                        <div class="leafimg leaf-field pointer-events-none absolute z-20 overflow-visible">
                           <img loading="lazy" src="assets/images/leafimg.png" alt="leafImg"
                              class="leaf-motion leaf-image absolute top-0 left-0 opacity-0 transform-gpu will-change-transform select-none" />
                        </div>
                     </div>
                  </div>
                  <!-- Right Image Collage -->
                  <div class="image-collage-sway collage-stage relative w-full mx-auto lg:ml-auto overflow-visible">
                     <!-- First image - no animation -->
                     <img loading="lazy" src="assets/images/turnImg.png" alt="Decorative"
                        class="collage-turn absolute z-20 select-none" />
                     <!-- Top Right Image -->
                     <div data-range="30" data-hover="20" data-idle="12" data-scale="1.03" data-dir="rtl"
                        class="sync-pan-item collage-item-top absolute right-0 z-20 cursor-pointer">
                        <div class="media-frame lefttop relative overflow-hidden bg-transparent">
                           <img loading="lazy" src="assets/images/about/image1.png" alt="" aria-hidden="true"
                              class="block w-full h-auto opacity-0 pointer-events-none select-none" />
                           <img loading="lazy" src="assets/images/about/image1.png" alt="Buffet Service"
                              class="sync-pan-inner pan-image-top absolute inset-0 h-full max-w-none object-cover transform-gpu will-change-transform pointer-events-none select-none" />
                           <div
                              class="overlay-base overlay-rounded absolute inset-0 bg-black/20 opacity-0 pointer-events-none">
                           </div>
                           <div
                              class="overlay-sweep overlay-sweep-right overlay-rounded absolute inset-y-0 bg-gradient-to-l from-black/30 via-black/15 to-transparent opacity-0 pointer-events-none">
                           </div>
                        </div>
                     </div>
                     <!-- Bottom Left Image -->
                     <div data-range="30" data-hover="20" data-idle="12" data-scale="1.03" data-dir="ltr"
                        class="sync-pan-item collage-item-bottom absolute z-10 cursor-pointer">
                        <div class="media-frame leftbottom relative overflow-hidden bg-transparent">
                           <img loading="lazy" src="assets/images/about/image2.png" alt="" aria-hidden="true"
                              class="block w-full h-auto opacity-0 pointer-events-none select-none" />
                           <img loading="lazy" src="assets/images/about/image2.png" alt="Plated Fine Dining"
                              class="sync-pan-inner pan-image-bottom absolute inset-0 h-full max-w-none object-cover transform-gpu will-change-transform pointer-events-none select-none" />
                           <div
                              class="overlay-base overlay-rounded absolute inset-0 bg-black/20 opacity-0 pointer-events-none">
                           </div>
                           <div
                              class="overlay-sweep overlay-sweep-left overlay-rounded absolute inset-y-0 bg-gradient-to-r from-black/30 via-black/15 to-transparent opacity-0 pointer-events-none">
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </section>

         <!-- ==================== SLIDER SECTION (With Premium Hover Effects) ==================== -->
         <!-- ==================== DIVERSE PLAYGROUNDS SECTION ==================== -->
