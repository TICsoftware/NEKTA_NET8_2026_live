                              <img loading="lazy" src="/Assets/images/insights/premium-catering.png" alt="Premium Catering"
                                 class="w-full object-cover" />
                           </div>
                           <div class="py-6">
                              <span class="pill inline-block bg-green text-cream text-xs font-medium px-2.5 py-1 rounded-lg">Case Study</span>
