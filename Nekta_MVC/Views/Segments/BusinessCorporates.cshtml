<!-- ==================== CTA ==================== -->
@foreach (var item in Model.Seeking_Elevated_DE_List.Where(x => x.IsBlock == 0))
{
    <section class="cta-section bg-darkcream section-spacing relative overflow-hidden">
        <img src="/Assets/images/bg-pattern.webp" alt="" class="w-full h-full absolute top-0 left-0" />
        <div class="container">
            <!-- Section Heading -->
            <div class="section-title-outer text-center max-w-6xl mx-auto">
                <h2 class="title-section text text-h2" data-leaf-target letters-slide-down text-split>
                    @Html.Raw(
                    !string.IsNullOrWhiteSpace(item.DisplayTitle)
                    ? item.DisplayTitle.CleanParagraphTags()
                    : item.Title)
            </h2>
            @if (!string.IsNullOrWhiteSpace(item.Intro))
                {
                  @Html.Raw(item.Intro.CleanParagraphTags())
                }
            </div>
            <!-- View All Button -->
            @if (!string.IsNullOrWhiteSpace(item.Url))
            {
                <div class="flex justify-center mt-6">
                    <a href="@item.Url" class="common-btn flex items-center gap-2 btn-slide-fill">
                        <span>@(!string.IsNullOrWhiteSpace(item.Url_Text) ? item.Url_Text : "Partner with Us")</span>
                        <img loading="lazy" src="/Assets/images/arrows/creamarrow-long-right.png" alt="Right Arrow" />
                    </a>
                </div>
            }
        </div>
    </section>
}



@section Scripts {
    <script src="~/Assets/js/inner-banner-script.js"></script>
