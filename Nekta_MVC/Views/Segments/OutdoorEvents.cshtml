@using Nekta_MVC.Helpers
@model Nekta_BusinessLogic.Entity.SegmentsModel
@{
    ViewData["Title"] = "Healthcare";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section head {

    <title>@Model.Content.cont_window_title</title>

    <meta content="@Model.Content.cont_metatag" name="keywords" />
    <meta content="@Model.Content.cont_metadesc" name="description" />


    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="" />
    <meta name="twitter:title" content="@Model.Content.ContTitle" />
    <meta name="twitter:description" content="@Model.Content.cont_metadesc" />


    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Nekta" />
    <meta property="og:title" content="@Model.Content.ContTitle" />
    <meta property="og:description" content="@Model.Content.cont_metadesc" />
    <meta property="og:url" content="https://www.nekta.com/" />
    <meta property="og:image" content="@Model.Content.cont_meta_image" />

    <meta itemprop="name" content="Nekta" />
    <meta itemprop="description" content="@Model.Content.cont_metadesc" />
    <meta itemprop="image" content="@Model.Content.cont_meta_image" />

    <!-- Facebook / Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nekta" />
    <meta property="og:title" content="@Model.Content.ContTitle" />
    <meta property="og:description" content="@Model.Content.cont_metadesc" />
    <meta property="og:image" content="@Model.Content.cont_meta_image" />
    <meta property="og:url" content="https://www.nekta.com/" />

    <link rel="canonical" href="@Model.Content.CanonicalUrl" />
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/css/center-mode-slider.css">
    <link rel="stylesheet" href="~/Assets/css/blogs-cards-slider.css">
    <link rel="stylesheet" href="~/Assets/css/thumb-slider.css" />
    <link rel="stylesheet" href="~/Assets/css/outdoorevents.css" />
    <link rel="stylesheet" href="~/Assets/css/page-intro-section.css" />
}




<!-- HERO BANNER END-->
@if (Model != null)
{
    @await Html.PartialAsync("~/Views/CommonComponent/_page_banner.cshtml", Model.Content)
}
<!-- HERO BANNER END -->
<!-- ====================INTRO DOUBLE IMAGE STRUCTURE CSS==================== -->
@foreach (var item in Model.Outdoor_Operation_List.Where(x => x.IsBlock == 0))
{
    <section class=" bc-experience-section relative section-spacing overflow-hidden page-intro-section">

        <div class="container relative z-10">
            <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

                <!-- Left: layered photo composition -->
                <div class="relative">
                    <div class="nourish-media-wrap relative">

                        <!-- back photo: chef portrait -->
                        <div class="nourish-photo nourish-photo-back">
                            <img loading="lazy" src="@item.Component_LHS_thumbnail"
                                alt="@item.Component_LHS_thumbnail_image_alt">
                        </div>

                        <!-- front photo: plating close-up, overlaps the back photo -->
                        <div class="nourish-photo nourish-photo-front">
                            <img loading="lazy" src="@item.ComponentThumbnail" alt="@item.ComponentThumbnailAltText">
                        </div>

                    </div>
                </div>
                <!-- Right: copy -->
                <div class="relative space-y-6 md:space-y-8 sm:max-w-[35vw]">
                    <div class="section-title-outer mx-auto max-w-5xl">
                        <h2 class="title-section text-h2 " data-leaf-target letters-slide-down text-split>
                            @Html.Raw(
                            !string.IsNullOrWhiteSpace(item.DisplayTitle)
                            ? item.DisplayTitle.CleanParagraphTags()
                            : item.Title)
                    </h2>

                </div>
                <div class="intro-outer-wrapper sm:pl-15">
                    <p>@Html.Raw(item.Intro.CleanParagraphTags())</p>
                </div>

            </div>
        </div>
    </div>
</section>
}

<!-- ==================== OUTDOOR CATERING EXCELLENCE ==================== -->
<!-- ==================== OUTDOOR CATERING EXCELLENCE ==================== -->
@foreach (var item in Model.Outdoor_Catering_Excellence_List.Where(x => x.IsBlock == 0))
{
    <section class="bc-catering-section relative  overflow-hidden">
        <div class="container-fluid relative z-10">



            <!-- Left side fork with pasta decorative image -->
            <img loading="lazy" src="@item.Component_LHS_thumbnail" alt="@item.Component_LHS_thumbnail_image_alt"
                class="bc-catering-deco bc-catering-deco--fork" aria-hidden="true" />

            <!-- Right side tomato splatter decorative image -->
            <img loading="lazy" src="@item.Component_right_image" alt="@item.Component_Right_image_alt"
                class="bc-catering-deco bc-catering-deco--tomato" aria-hidden="true" />

            <!-- Dome shape with background image + centered copy -->
            <div class="bc-catering-dome">
                <img loading="lazy" src="@item.Componentbackground" alt="@item.ComponentbackgroundAltText"
                    class="bc-catering-dome-bg" aria-hidden="true" />
                <div class="bc-catering-dome-overlay"></div>
                <div class="bc-catering-dome-content">
                    <div class="section-title-outer text-center mx-auto max-w-5xl">
                        <h2 class="title-section text-h2" data-leaf-target letters-slide-down text-split>
                            @Html.Raw(
                            !string.IsNullOrWhiteSpace(item.DisplayTitle)
                            ? item.DisplayTitle.CleanParagraphTags()
                            : item.Title)
                    </h2>
                </div>

                @if (!string.IsNullOrWhiteSpace(item?.Intro))
                    {
                        @Html.Raw(item.Intro)
                    }

                </div>
            </div>



        </div>
    </section>
}




<!-- ==================== Services for Outdoor Events ==================== -->
@if (Model?.Services_For_Outdoor_Events_List != null && Model.Services_For_Outdoor_Events_List.Any())
{
    @await Html.PartialAsync("~/Views/CommonComponent/_life_is_beautiful_plate.cshtml",
    Model.Services_For_Outdoor_Events_List)
}



<!-- ==================== TECHNOLOGY SECTION ==================== -->
@if (Model.Nektas_Edge_For_Outdoor_Events_List != null && Model.Nektas_Edge_For_Outdoor_Events_List.Any())
{
    @await Html.PartialAsync("~/Views/CommonComponent/_nekta_edge.cshtml", Model.Nektas_Edge_For_Outdoor_Events_List)
}


<!-- ==================== CTA ==================== -->
@if (Model?.Proof_Is_On_The_Plate_Outdoor_List != null && Model.Proof_Is_On_The_Plate_Outdoor_List.Any())
{
    @await Html.PartialAsync("~/Views/CommonComponent/_title_intro_cta.cshtml", Model.Proof_Is_On_The_Plate_Outdoor_List)
}





@section Scripts {
    <script src="~/Assets/js/inner-banner-script.js"></script>
    <script src="~/Assets/js/center-mode-slider.js"></script>
    <script src="~/Assets/js/blogs-cards-slider.js"></script>
    <script src="~/Assets/js/thumb-slider.js"></script>
    <script src="~/Assets/js/outdoorevents.js"></script>
}