@model List<CmsMenu>
@using Core_project_BusinessLogic.Entity

@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    ViewData["Title"] = "List Menu";
}

@{
   
    var allMenus = ViewBag.AllMenus as List<CmsMenu> ?? new List<CmsMenu>();
}

<div class="container mt-4">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="/Admin/Dashboard">Admin</a>
            </li>
            <li class="breadcrumb-item active">
                Menu Management
            </li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <div>
            <h2 class="mb-0">Menu Management</h2>
            <small class="text-muted">
                Manage website navigation menus
            </small>
        </div>

        <div>
            <a href="/CmsMenuAdmin/AddEdit"
               class="btn btn-success me-2">
                + Add New Menu
            </a>

        <a href="/CmsMenuAdmin/GenerateMenu"
   class="btn btn-primary">
    Generate Menu HTML
</a>
        </div>

    </div>

    <hr />

    <!-- Menu Table -->
    <table class="table table-bordered table-striped">

        <thead class="table-dark">
            <tr>
                <th width="60">ID</th>
                <th>Menu Title</th>
                <th>Parent Menu</th>
                <th>Template</th>
                <th width="100">Order</th>
               @* <th width="100">Active</th> *@
              
                <th width="120">Action</th>
            </tr>
        </thead>

        <tbody>

            @if (Model != null && Model.Count > 0)
            {
                foreach (var m in Model)
                {
                    var parent = allMenus.FirstOrDefault(x => x.MenuId == m.ParentId);

                    <tr>

                        <td>@m.MenuId</td>

                        <td>
                            <strong>@m.Title</strong>
                        </td>

                        <td>
                            @(parent != null ? parent.Title : "Main Menu")
                        </td>

                        <td>
                            @m.TemplateId
                        </td>

                        <td>
                            @m.DisplayOrder
                            </td>
                      <td>
@* 
@if (m.IsActive)
{
    <span class="badge bg-success">Active</span>
}
else
{
    <span class="badge bg-danger">Inactive</span>
} *@

</td>

                        <td>

                            <a href="/CmsMenuAdmin/AddEdit/@m.MenuId"
                               class="btn btn-sm btn-primary">
                                Edit
                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        No menus found
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>