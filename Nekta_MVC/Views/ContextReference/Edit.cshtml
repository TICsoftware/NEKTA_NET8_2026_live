@model Core_project_BusinessLogic.Entity.ContextReference
@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    ViewData["Title"] = "Edit components Reference";
    var encId = ViewBag.EncId as string;
}

<div class="page-heading">
    <div class="page-title">
        <div class="row">
            <div class="col-12 col-md-6 order-md-2 order-first">
                <nav aria-label="breadcrumb" class="breadcrumb-header float-start">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/manage/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">
                           Edit Components Reference
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
<h2>Edit Components Reference</h2>

<form id="frmEdit">
    <input type="hidden" id="encId" name="encId" value="@encId" />
    <partial name="_ContextReferenceForm" model="Model" />

    <button type="button" id="btnEdit" class="btn btn-success cms-btn-custom">Update</button>
    <a asp-action="Index" class="btn btn-secondary ms-2 cms-btnsecondary-custom">Cancel</a>
</form>

<div id="editResult" class="mt-3"></div>
</div>
@section Scripts {
    <script>
        $(function () {
            $("#btnEdit").click(function () {
                var enc = $("#encId").val();
                var data = $("#frmEdit").serialize();

                $.ajax({
                    url: '@Url.Action("Edit","ContextReference")' + '?encId=' + encodeURIComponent(enc),
                    method: 'POST',
                    data: data,
                    success: function (res) {
                        if (res.success) {
                            $("#editResult").html('<div class="alert alert-success">' + res.message + '</div>');
                            setTimeout(function () { window.location = '@Url.Action("Index","ContextReference")'; }, 900);
                        } else {
                            $("#editResult").html('<div class="alert alert-danger">' + res.message + '</div>');
                        }
                    },
                    error: function () {
                        $("#editResult").html('<div class="alert alert-danger">Server error</div>');
                    }
                });
            });
        });
    </script>
}
