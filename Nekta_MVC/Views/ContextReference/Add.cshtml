@model Core_project_BusinessLogic.Entity.ContextReference
@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    ViewData["Title"] = "Add components Reference";
}

<div class="page-heading">
    <div class="page-title">
        <div class="row">
            <div class="col-12 col-md-6 order-md-2 order-first">
                <nav aria-label="breadcrumb" class="breadcrumb-header float-start">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/manage/dashboard">Dashboard</a></li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Add Components Reference
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
<h2>Add Components Reference</h2>

<form id="frmAdd">
    <partial name="_ContextReferenceForm" model="Model" />

    <div class="text-center">
        <button type="button" id="btnAdd" class="btn btn-primary cms-btn-custom">Save</button>
        <a asp-action="Index" class="btn btn-secondary cms-btnsecondary-custom ms-2">Cancel</a>
    </div>
</form>

<div id="addResult" class="mt-3"></div>
</div>
@section Scripts {
    <script>
        $(function () {
            $("#btnAdd").click(function () {
                var data = $("#frmAdd").serialize();
                $.ajax({
                    url: '@Url.Action("Add","ContextReference")',
                    method: 'POST',
                    data: data,
                    success: function (res) {
                        if (res.success) {
                            $("#addResult").html('<div class="alert alert-success">' + res.message + '</div>');
                            setTimeout(function () { window.location = '@Url.Action("Index","ContextReference")'; }, 900);
                        } else {
                            $("#addResult").html('<div class="alert alert-danger">' + res.message + '</div>');
                        }
                    },
                    error: function () {
                        $("#addResult").html('<div class="alert alert-danger">Server error</div>');
                    }
                });
            });
        });
    </script>
}
