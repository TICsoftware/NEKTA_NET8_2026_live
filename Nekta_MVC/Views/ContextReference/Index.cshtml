</div>


<div class="modal fade spot-layoutModal" id="layoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content shadow-lg rounded-4 border-0">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title fw-semibold">
                    Layout Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body p-4" id="layoutContainer">
                  @* <!-- html_layout injected here --> *@
            </div>

            <!-- Footer -->
            <div class="modal-footer rounded-bottom-4">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>
@section Scripts {
<script>
    function showLayout(encId) {
        fetch('/ContextReference/Render?encId=' + encodeURIComponent(encId))
            .then(res => res.json())
            .then(data => {
                document.getElementById('layoutContainer').innerHTML =  data.finalHtml || '<p>No layout defined</p>';

                new bootstrap.Modal(
                    document.getElementById('layoutModal')
                ).show();
            })
            .catch(err => {
                console.error(err);
                alert('Failed to load layout');
            });
    }
</script>
}


