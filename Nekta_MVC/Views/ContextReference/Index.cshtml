 <button type="button"
        class="btn btn-sm btn-outline-primary"
        onclick="showLayout('@CryptoEngine.Encrypt(item.ID.ToString())')">
    View Layout
</button>
</div>

                    @if (item.Status == 1)
                    {
                        <div class="d-inline-block me-2 mb-1">
                        <a asp-action="Deactivate" asp-route-encId="@CryptoEngine.Encrypt(item.ID.ToString())" class="btn btn-sm btn-outline-danger" onclick="return confirm('Deactivate?')">Deactivate</a>
                        </div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == curPage ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = i, search = search })">@i</a>
            </li>
        }
    </ul>
</nav>

