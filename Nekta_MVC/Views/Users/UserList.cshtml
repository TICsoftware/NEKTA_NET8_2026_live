@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    ViewData["Title"] = "User list";
    string returnUrl = Context.Request.Query["ReturnUrl"].ToString();
}


<h2>User Management</h2>

<table class="table table-striped table-bordered">

    <thead class="table-dark">
        <tr>
            <th>👤 Email</th>
            <th>🔐 2FA Status</th>
            <th>🕒 Last Login</th>
            <th style="width:420px">⚙ Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var user in Model)
        {
            <tr>

                <td>@user.emailid</td>

                <td>
                    @if (user.Is2FAEnabled)
                    {
                        <span class="badge bg-success">Enabled</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Disabled</span>
                    }
                </td>

                <td>
                    @if (user.LastLogin != null)
                    {
                        @user.LastLogin.ToString("dd-MMM-yyyy HH:mm")
                    }
                    else
                    {
                        <span class="text-muted">Never</span>
                    }
                </td>

                <td>

                    <button class="btn btn-success btn-sm"
                        onclick="open2FAPopup('/Users/Setup2FA?email=@user.emailid', 'Setup')">
                        🔐 Setup
                    </button>

                    <button class="btn btn-warning btn-sm"
                        onclick="open2FAPopup('/Users/Reset2FA?email=@user.emailid', 'Reset')">
                        🔄 Reset
                    </button>

                    <a asp-action="Disable2FA" asp-route-email="@user.emailid" class="btn btn-danger btn-sm"
                        onclick="return confirm('Disable 2FA for this user?')">
                        ❌ Disable
                    </a>

                    <a asp-action="LoginLogs" asp-route-email="@user.emailid" class="btn btn-info btn-sm">
                        📊 Logs
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>



<div class="modal fade" id="twoFAModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
               <h5 class="modal-title" id="twoFATitle">Setup 2FA</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="qrContent">

                Loading QR Code...

            </div>

        </div>
    </div>
</div>

<script>
    function open2FAPopup(url, title) {
        // Set dynamic title
        document.getElementById("twoFATitle").innerText = title;

        fetch(url)
            .then(res => res.text())
            .then(data => {
                document.getElementById("qrContent").innerHTML = data;
                var modal = new bootstrap.Modal(document.getElementById('twoFAModal'));
                modal.show();
            });
    }
</script>