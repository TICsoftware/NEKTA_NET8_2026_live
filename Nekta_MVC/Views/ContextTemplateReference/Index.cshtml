<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == curPage ? "active" : "")">
                <a class="page-link" href="@Url.Action("Index", new { page = i, templateId = ViewBag.SelectedTemplateId, contextId = ViewBag.SelectedContextId, label = ViewBag.Label })">@i</a>
            </li>
        }
    </ul>
</nav>
 <div class="modal fade spot-layoutModal" id="layoutModalTemplate" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Template Preview</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" id="layoutContainerTemplate"></div>
