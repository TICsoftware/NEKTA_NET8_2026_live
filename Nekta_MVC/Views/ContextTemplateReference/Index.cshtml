@model IEnumerable<Core_project_BusinessLogic.Entity.ContextTemplateReference>

@using Core_project_BusinessLogic;

@{
    Layout = "~/Views/Shared/Manage/_Layout_RHS.cshtml";
    int curPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<h2>Component Template Mapping</h2>

<!-- ================= SEARCH ================= -->
<form asp-action="Index" method="get" class="card p-3 mb-4">
    <div class="row">

        <div class="col-md-3">
            <label>Component Layout</label>
            <select name="contextId" class="form-control"
                asp-items="@(new SelectList(ViewBag.ContextMasters, "ID", "Title", ViewBag.SelectedContextId))">
                <option value="">-- All --</option>
            </select>
        </div>

        <div class="col-md-3">
            <label>Template</label>
            <select name="templateId" class="form-control"
                asp-items="@(new SelectList(ViewBag.TemplateMasters, "ID", "Name", ViewBag.SelectedTemplateId))">
                <option value="">-- All --</option>
            </select>
        </div>

        <div class="col-md-3">
            <label>Label</label>
            <input name="label" value="@ViewBag.Label" class="form-control" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-primary w-100">
                Search
            </button>
        </div>

    </div>
</form>


<!-- ================= ADD NEW MAPPING ================= -->
<form asp-action="Add" method="post" class="card p-3 mb-4" id="mappingForm">
    @if (TempData["MappingError"] != null)
    {
        <div class="text-danger mb-2">@TempData["MappingError"]</div>
    }
    <div class="row">

        <div class="col-md-3">
            <label>Component Layout</label>
            <select name="Context_Master_ID" id="ddContext" class="form-control"
                asp-items="@(new SelectList(ViewBag.ContextMasters, "ID", "Title", ViewBag.SelectedContextId))">
            </select>
            <span id="ctxError" class="text-danger"></span>
        </div>

        <div class="col-md-3">
            <label>Template</label>
            <select name="Template_Master_ID" id="ddTemplate" class="form-control"
                asp-items="@(new SelectList(ViewBag.TemplateMasters, "ID", "Name", ViewBag.SelectedTemplateId))">
            </select>
            <span id="templateError" class="text-danger"></span>
        </div>

        <div class="col-md-2">
            <label>Sequence</label>
            <input name="Sequence" id="txtSequence" class="form-control" type="number" min="1" max="9999" />
            <span id="seqError" class="text-danger"></span>
        </div>

        <!-- NEW FIELD -->
        <div class="col-md-2">
            <label>Label</label>
            <input name="Component_Label"
                   id="txtLabel"
                   class="form-control"
                   maxlength="100" />
            <span id="labelError" class="text-danger"></span>
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-primary w-100">
                Mapping
            </button>
        </div>

    </div>
</form>


