@model List<Core_project_BusinessLogic.Entity.ContextFieldWithValue>

@using System.Text.Json
@{
    Layout = null;
    var reference = ViewBag.Reference;
    var mode = ViewBag.Mode as string ?? "Block";
}

<div class="page-heading">

    <h2>
        @(mode == "Main"
            ? "Edit Main Component: " + (reference?.Context_Title ?? "Reference")
            : "Edit Block Component 12: " + (reference?.Context_Title ?? "Reference"))
    </h2>

    <form id="EditContextDetailsForm"
          asp-action="EditDataSubmit"
          method="post"
          asp-controller="DynamicData">

        <input type="hidden" name="referenceId" value="@reference.ID" />
        <input type="hidden" name="masterId" value="@reference.Context_Master_ID" />
        <input type="hidden" name="groupId" value="@ViewBag.GroupId" />
       @*adedd for contid*@

          <input type="hidden" name="contid" value="@ViewBag.ContId" />
          <input type="hidden" name="is_block" value="@ViewBag.is_block" />
        @foreach (var f in Model)
        {
            <div class="mb-3">

                <label>@f.name</label>

                @* TEXTBOX *@
                @if (f.field_type_id == 1)
                {
                    <input name="@f.name_key"
                           value="@f.content"
                           class="form-control dynamic-field"
                           data-required="@(f.is_required == 1 ? "true" : "false")"
                           data-validation="@f.field_validation"
                           data-message="@f.custom_validation"
                           data-name="@f.name" />
                }

                @* DROPDOWN *@
                else if (f.field_type_id == 2)
                {
                    var opts = new List<string>();
                    if (!string.IsNullOrWhiteSpace(f.field_options))
                    {
                        try { opts = JsonSerializer.Deserialize<List<string>>(f.field_options); } catch { }
                    }

                    <select name="@f.name_key"
                            class="form-control dynamic-field"
                            data-required="@(f.is_required == 1 ? "true" : "false")"
                            data-name="@f.name">

                        <option value="">-- Select --</option>

                        @foreach (var o in opts)
                        {
                            <option value="@o" selected="@(o == f.content)">
                                @o
                            </option>
                        }
                    </select>
                }

                @* CKEDITOR *@
                else if (f.field_type_id == 7)
                {
                    <textarea name="@f.name_key"
                              class="form-control editor-full dynamic-field"
                              data-required="@(f.is_required == 1 ? "true" : "false")"
                              data-validation="@f.field_validation"
                              data-message="@f.custom_validation"
                              data-name="@f.name">@f.content</textarea>
                }

                @* IMAGE *@
                else if (f.field_type_id == 8)
                {
                    <button type="button" id="btnFile"
                            class="btn btn-outline-primary select-media"
                            data-field="@f.name_key">
                        Change File
                    </button>
                    
                     <input type="hidden" name="@($"{f.name_key}_new")" />
                    <input type="hidden" name="@($"{f.name_key}_existing")" value="@f.File_path" />

                    <img src="@f.File_path_name" style="max-height:120px" />

                     
                   <img src="@f.File_path_name" style="max-height:120px" class="imgPreview" />
                }

                <input type="hidden" name="@($"{f.name_key}_detail_id")" value="@f.detail_id" />

                <span class="text-danger error-msg"></span>

            </div>
        }

        <button class="btn btn-success">Update</button>
    </form>
</div>

<!-- ============================
     ❌ REMOVE importmap + module
     ============================ -->

<!-- ============================
     ✅ SCRIPT SECTION (FIXED)
     ============================ -->
<script>

(function () {

    // ============================
    // 🔹 VALIDATION
    // ============================
    window.validateDynamicForm = function () {

        let isValid = true;
        $(".error-msg").text("");

        $(".dynamic-field").each(function () {

            let value = ($(this).val() || "").toString();
            let required = $(this).data("required") == "true";
            let validation = $(this).data("validation");
            let message = $(this).data("message");
            let name = $(this).data("name");

            let errorContainer = $(this).closest(".mb-3").find(".error-msg");

            // REQUIRED
            if (required && value.trim() === "") {

                errorContainer.text(message || (name + " is required"));
                this.scrollIntoView({ behavior: 'smooth', block: 'center' });
                $(this).focus();

                isValid = false;
                return false;
            }

            // REGEX
            if (validation && value) {
                try {
                    let regex = new RegExp(validation);

                    if (!regex.test(value)) {

                        errorContainer.text(message || (name + " is invalid"));
                        this.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        $(this).focus();

                        isValid = false;
                        return false;
                    }
                }
                catch {
                    console.error("Invalid regex for", name);
                }
            }

        });

        return isValid;
    };


    // ============================
    // 🔹 FORM SUBMIT (FIXED)
    // ============================
    $(document)
        .off("submit.editData", "#EditContextDetailsForm")
        .on("submit.editData", "#EditContextDetailsForm", function (e) {

            e.preventDefault();

            console.log("EDIT SUBMIT CALLED");

            // 🔥 CKEDITOR SYNC
            if (window.syncCkEditorsToSource) {
                window.syncCkEditorsToSource(
                    document.getElementById("EditContextDetailsForm")
                );
            }

            if (!validateDynamicForm()) return;

            var $form = $(this);

            $.ajax({
                url: $form.attr("action"),
                type: "POST",
                data: $form.serialize(),

                success: function (response) {

                    if (response.success) {

                        alert("Data updated successfully");               
                       // window.parent.Load_Edit_context_Temp_details(false);         

                        // var modalEl = document.getElementById('modal_spottemplates');
                       // if (modalEl) {
                        //    var modal = bootstrap.Modal.getInstance(modalEl);
                        //    if (modal) modal.hide();
                       // }

                        // 🔥 REFRESH
                        
                       // if (window.parent && window.parent.Load_Edit_context_Temp_details) {
                            window.parent.Load_Edit_context_Temp_details(true);
                       // }               
            

                    } else {
                        alert(response.message);
                    }
                },

                error: function () {
                    alert("Error occurred");
                }
            });

        });


    // ============================
    // 🔹 CKEDITOR INIT (IMPORTANT)
    // ============================
    setTimeout(function () {
        if (window.initCkEditors) {
            window.initCkEditors(document);
        }
    }, 200);

})();
</script>